# ======================
# DJANGO CORE
# ======================
DJANGO_SECRET_KEY=dev-secret-key-only-for-local
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ======================
# DATABASE (MongoDB local hoặc Atlas test)
# ======================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=robot_local

# ======================
# AUTH / JWT
# ======================
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# ======================
# CORS / CSRF (local FE)
# ======================
CORS_ALLOW_ALL_ORIGINS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ======================
# ROBOT SERVER (Flask / ROS2)
# ======================
ROBOT_SERVER_BASE_URL=http://localhost:8001
ROBOT_SERVER_TIMEOUT=5

# ======================
# SERVER
# ======================
PORT=8000
