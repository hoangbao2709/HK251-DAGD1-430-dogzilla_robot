@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
}
skinparam actor {
  BorderColor #666666
}

actor User

rectangle "Web Robot Control System" {
  usecase "Register" as UC_Register
  usecase "Login/Logout" as UC_Login
  usecase "Manage Robot List" as UC_ManageRobot
  usecase "Connect to Robot" as UC_Connect
  usecase "Disconnect Robot" as UC_Disconnect

  usecase "Monitor Robot Status" as UC_Status
  usecase "View Connection Status" as UC_ConnectionStatus
  usecase "View System Logs" as UC_Logs
  usecase "View Live Video Stream" as UC_Video

  usecase "Manual Control" as UC_Manual
  usecase "Start Autonomous Task" as UC_Autonomous
  usecase "Select Task Mode" as UC_TaskMode
  usecase "Select Target" as UC_Target
  usecase "Manage Mapping Localization" as UC_Mapping
  usecase "Scan / Verify QR" as UC_ScanQR

  usecase "Dynamic Obstacle Avoidance" as UC_Obstacle
  usecase "Read SLAM / LiDAR Scan" as UC_LidarScan
  usecase "Replan Path" as UC_Replan
  usecase "Log Obstacle Event" as UC_LogObstacle

  usecase "QR Code Localization" as UC_QRLocalization
  usecase "Estimate QR Pose" as UC_QRPose
  usecase "Show QR Position" as UC_QRPosition

  usecase "AI Voice" as UC_AIVoice
  usecase "Speech to Text" as UC_SpeechToText
  usecase "Map Voice Command" as UC_MapCommand
  usecase "Execute Robot Tool" as UC_ExecuteTool
}

User --> UC_Register
User --> UC_Login
User --> UC_ManageRobot
User --> UC_Connect
User --> UC_Status
User --> UC_Video
User --> UC_Manual
User --> UC_Autonomous
User --> UC_Mapping
User --> UC_AIVoice

UC_Connect ..> UC_Disconnect : <<extend>>
UC_Status ..> UC_ConnectionStatus : <<include>>
UC_Status ..> UC_Logs : <<include>>

UC_Autonomous ..> UC_TaskMode : <<include>>
UC_Autonomous ..> UC_Target : <<include>>
UC_Autonomous ..> UC_ScanQR : <<include>>
UC_Autonomous ..> UC_Obstacle : <<include>>

UC_Mapping ..> UC_ScanQR : <<include>>
UC_Mapping ..> UC_QRLocalization : <<include>>

UC_Obstacle ..> UC_LidarScan : <<include>>
UC_Obstacle ..> UC_Replan : <<include>>
UC_Obstacle ..> UC_LogObstacle : <<include>>

UC_QRLocalization ..> UC_ScanQR : <<include>>
UC_QRLocalization ..> UC_QRPose : <<include>>
UC_QRLocalization ..> UC_QRPosition : <<include>>

UC_AIVoice ..> UC_SpeechToText : <<include>>
UC_AIVoice ..> UC_MapCommand : <<include>>
UC_AIVoice ..> UC_ExecuteTool : <<include>>
UC_AIVoice ..> UC_Manual : <<extend>>
UC_AIVoice ..> UC_Autonomous : <<extend>>

note right of UC_Obstacle
  Frontend reads SLAM scan points
  and nearest obstacle ahead.
  Backend stores obstacle_detected
  events for session summary.
end note

note right of UC_QRLocalization
  Camera frame -> QR detection
  -> pose/distance/target payload
  -> top-down QR display.
end note

note right of UC_AIVoice
  Browser speech recognition or text
  -> /command/text/
  -> MCP robot tool execution.
end note
@enduml
