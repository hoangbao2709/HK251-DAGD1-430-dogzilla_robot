<mxfile host="app.diagrams.net">
  <diagram id="frontend-backend-ros2-architecture" name="Frontend Backend ROS2 Architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Kien truc tong the Frontend - Backend - ROS2" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="350" y="50" width="700" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Frontend Web UI&#xa;Manual / QR / Voice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="120" y="250" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="backend" value="Backend Server&#xa;Django REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="430" y="250" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ros_bridge" value="ROS2 / MCP Bridge&#xa;Convert request to robot command" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="740" y="250" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="robot" value="Dogzilla Robot&#xa;Move / camera / sensors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1080" y="250" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="command_label" value="Command flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="590" y="170" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="response_label" value="Response / telemetry" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="590" y="475" width="220" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="e_frontend_backend" value="REST request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="frontend" target="backend" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_backend_ros" value="Handle command" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="backend" target="ros_bridge" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ros_robot" value="Robot action" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="ros_bridge" target="robot" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e_robot_ros" value="sensor / camera data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="robot" target="ros_bridge" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1190" y="430"/>
              <mxPoint x="860" y="430"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ros_backend" value="result / state" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="ros_bridge" target="backend" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="860" y="430"/>
              <mxPoint x="540" y="430"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_backend_frontend" value="JSON response" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;fontSize=14;" parent="1" source="backend" target="frontend" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="430"/>
              <mxPoint x="230" y="430"/>
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
